{
    "task": [
        {
            "name": "进入游戏",
            "group": [
                "daily"
            ],
            "default_check": true,
            "entry": "启动",
            "pipeline_override": {
                "检查主界面2": {
                    "action": {
                        "type": "Custom",
                        "param": {
                            "custom_action": "Notice",
                            "custom_action_param": {
                                "action": "set_black_card"
                            }
                        }
                    }
                }
            },
            "option": [
                "MAS通知处理"
            ],
            "label": "$task.进入游戏"
        }
    ],
    "option": {
        "MAS通知处理": {
            "label": "$option.MAS通知处理.label",
            "description": "$option.MAS通知处理.description",
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "MAS联动处理-检查到维护公告_将发送假通知": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "MAS联动处理-检查到维护公告_将发送假通知": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "No"
        }
    }
}
