                "lower": [
                    170,
                    60,
                    0
                ],
                "upper": [
                    180,
                    90,
                    55
                ],
                "connected": true,
                "count": 200
            }
        }
    },
    "检查支援类型角色是否被选中": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "检查支援类型角色",
                "roi_offset": [
                    -100,
                    60,
                    30,
                    -10
                ],
                "expected": [
                    "编队中",
                    "編隊中"
                ],
                "only_rec": true
            }
        },
        "next": [
            "识别囚笼次数_辅助"
