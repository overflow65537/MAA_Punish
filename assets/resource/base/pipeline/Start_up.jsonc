        "on_error": [
            "服务器错误提示"
        ]
    },
    "服务器错误提示": {
        "next": [
            "启动"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "[color:Tomato]服务器错误,请选择所在服务器(比如b服)[/color]"
        }
    },
    "切换主界面状态": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1165,
                    476,
                    77,
                    62
                ],
                "template": [
                    "启动/切换主界面状态_默认.png",
                    "启动/切换主界面状态_家园.png",
                    "启动/切换主界面状态_白梦游弋.png",
