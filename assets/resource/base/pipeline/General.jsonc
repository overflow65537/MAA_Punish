        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    27,
                    10,
                    51,
                    53
                ],
                "template": "指挥局/返回.png"
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1000
    },
    "返回主菜单_err": {
        "next": [
            "点击频率过快",
            "错误处理流程"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$focus.base.General.返回主菜单_err.Node.Recognition.Succeeded",
            "aborted": true
        }
    },
    "错误处理流程": {
        "next": [
            "检查主界面",
            "退出血清界面_err",
            "返回主菜单",
            "返回主菜单_图标",
            "[JumpBack]确定",
            "[JumpBack]选择宝箱奖励_厄愿潮声",
            "[JumpBack]关闭奖励",
            "[JumpBack]等级提升",
            "[JumpBack]返回"
        ],
        "on_error": [
            "重启游戏"
        ]
    },
    "重启游戏": {
        "action": {
            "type": "StopApp",
            "param": {
                "package": "com.kurogame.haru.hero"
            }
        },
        "next": [
            "启动"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$focus.base.General.重启游戏.Node.Recognition.Succeeded",
        }
    },
