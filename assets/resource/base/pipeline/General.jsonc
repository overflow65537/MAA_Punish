{
    "自动qte": {
        "enabled": true
    },
    "自动切换": {
        "enabled": true
    },
    "关闭奖励": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    409,
                    176,
                    491,
                    150
                ],
                "expected": [
                    "^(获得)?奖励$",
                    "^(獲得)?獎勵$"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    446,
                    30
                ]
            }
        },
        "post_wait_freezes": {
            "time": 500,
            "timeout": 2000
        }
    },
    "返回主菜单": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    201,
