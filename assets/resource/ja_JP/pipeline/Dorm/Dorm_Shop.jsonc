    "打开遣测商店": {
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "sub_name": "_目标文字",
                        "recognition": {
                            "type": "OCR",
                            "param": {
                                "roi": [
                                    9,
                                    156,
