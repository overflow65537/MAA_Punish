            "param": {
                "roi": [
                    700,
                    620,
                    120,
                    70
                ],
                "template": "界面/大廳/購入.png",
                "threshold": 0.6,
                "green_mask": true
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    1221,
                    74,
                    1,
                    1
                ]
            }
        }
    },
