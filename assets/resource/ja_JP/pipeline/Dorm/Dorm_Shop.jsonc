                                    442
                                ],
                                "expected": [
                                    "ストア"
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "ColorMatch",
                            "param": {
                                "roi": "_目标文字",
                                "lower": [
                                    167,
                                    178,
                                    200
                                ],
                                "upper": [
                                    244,
                                    245,
                                    248
                                ],
                                "connected": true,
                                "count": 500
                            }
                        }
                    }
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500
    },
