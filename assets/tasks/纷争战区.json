{
    "task": [
        {
            "name": "纷争战区",
            "default_check": true,
            "entry": "纷争战区",
            "description": "<p>自动首通纷争战区；如已通关则仅领取奖励。</p><p><b>速通</b>：每周二5点后可运行2次，首次运行后需等待24小时。</p>",
            "speedrun": {
                "mode": "weekly",
                "trigger": {
                    "weekly": {
                        "weekday": [
                            2
                        ],
                        "hour_start": 5
                    }
                },
                "run": {
                    "count": 2,
                    "min_interval_hours": 24
                }
            }
        }
    ],
    "option": {
        "自行选择编队_战区": {
            "label": "自行选择编队",
            "type": "switch",
            "default": false,
            "description": "<p>开启后将自行选择编队，关闭后将使用默认编队。</p>",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {},
                    "option": [
                        "选择火队_战区",
                        "选择雷队_战区",
                        "选择冰队_战区",
                        "选择暗队_战区",
                        "选择空队_战区",
                        "选择物理队_战区",
                        "选择特性队_战区"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {}
                }
            ]
        },
        "选择火队_战区": {
            "label": "选择火队",
            "description": "<p>输入火队编队名称，需与游戏内预设编队名称完全一致。</p>",
            "type": "input",
            "inputs": [
                {
                    "name": "编队名",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "查看地图_火区": {
                    "action": {
                        "type": "Custom",
                        "param": {
                            "custom_action": "PPOverride",
                            "custom_action_param": {
                                "选择预设": {
                                    "expected": "{编队名}"
                                },
                                "识别人物": {
                                    "enabled": true
                                }
                            }
                        }
                    },
                    "next": [
                        "切换预设"
                    ]
                }
            }
        },
