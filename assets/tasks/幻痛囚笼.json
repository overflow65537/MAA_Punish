{
    "task": [
        {
            "name": "幻痛囚笼",
            "default_check": true,
            "entry": "幻痛囚笼",
            "description": "<p>自动战斗幻痛囚笼，并自动选择人物作战；请注意角色锁定状态。</p><p>终级区需要自行选择非在岗角色,防止占用在岗角色</p><p><b>速通</b>：每周二5点后可运行2次，首次运行后需等待24小时。</p>",
            "option": [
                "选择区域",
                "自行选择编队_囚笼"
            ],
            "speedrun": {
                "mode": "weekly",
                "trigger": {
                    "weekly": {
                        "weekday": [
                            2
                        ],
                        "hour_start": 5
                    }
                },
                "run": {
                    "count": 2,
                    "min_interval_hours": 24
                }
            }
        }
    ],
    "option": {
        "选择区域": {
            "cases": [
                {
                    "name": "高级区",
                    "pipeline_override": {}
                },
                {
                    "name": "终级区",
                    "pipeline_override": {
                        "选择区域": {
                            "recognition": {
                                "param": {
                                    "expected": "终级"
                                }
                            }
                        }
                    },
                    "option": [
                        "选择终极区战斗角色"
                    ]
                }
            ]
        },
        "自行选择编队_囚笼": {
            "label": "自行选择编队",
            "type": "switch",
            "default": false,
            "description": "<p>开启后将自行选择编队，关闭后将使用自动编队。</p>",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {},
                    "option": [
                        "选择火队_囚笼",
                        "选择雷队_囚笼",
                        "选择冰队_囚笼",
                        "选择暗队_囚笼",
                        "选择物理队_囚笼"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {}
                }
            ]
        },
        "选择火队_囚笼": {
            "label": "选择火队",
            "description": "<p>输入火队编队名称，需与游戏内预设编队名称完全一致。</p>",
            "type": "input",
            "inputs": [
                {
                    "name": "编队名",
                    "pipeline_type": "string",
                    "verify": "^\\s*\\S.*$",
                    "pattern_msg": "需要输入编队名"
                }
            ],
            "pipeline_override": {
                "查看Boss_火队": {
                    "action": {
                        "type": "Custom",
                        "param": {
                            "custom_action": "PPOverride",
                            "custom_action_param": {
                                "选择预设": {
                                    "expected": "{编队名}"
                                },
                                "识别人物": {
                                    "enabled": true
                                }
                            }
                        }
                    },
                    "next": [
                        "切换预设"
                    ]
                }
            }
        },
