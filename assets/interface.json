    "option": {
        "角色缓存更新频率": {
            "label": "$option.角色缓存更新频率.label",
            "description": "$option.角色缓存更新频率.description",
            "type": "select",
            "cases": [
                {
                    "name": "每周",
                    "pipeline_override": {
                        "是否需要缓存": {
                            "recognition": {
                                "param": {
                                    "custom_recognition_param": {
                                        "update_frequency": "weekly"
                                    }
                                }
                            }
                        },
                        "选择角色程序": {
                            "attach": {
                                "update_frequency": "weekly"
                            }
                        },
                        "选择角色程序_onlyNode": {
                            "attach": {
                                "update_frequency": "weekly"
                            }
                        },
                        "选择角色程序_矩阵循生": {
                            "attach": {
                                "update_frequency": "weekly"
                            }
                        }
                    },
                    "label": "$case.角色缓存更新频率.每周"
                },
                {
                    "name": "每月",
                    "pipeline_override": {
                        "是否需要缓存": {
                            "recognition": {
                                "param": {
                                    "custom_recognition_param": {
                                        "update_frequency": "monthly"
                                    }
                                }
                            }
                        },
                        "选择角色程序": {
                            "attach": {
                                "update_frequency": "monthly"
                            }
                        },
                        "选择角色程序_onlyNode": {
                            "attach": {
                                "update_frequency": "monthly"
                            }
                        },
                        "选择角色程序_矩阵循生": {
                            "attach": {
                                "update_frequency": "monthly"
                            }
                        }
                    },
                    "label": "$case.角色缓存更新频率.每月"
                },
                {
                    "name": "永不过期",
                    "pipeline_override": {
                        "是否需要缓存": {
                            "recognition": {
                                "param": {
                                    "custom_recognition_param": {
                                        "update_frequency": "never"
                                    }
                                }
                            }
                        },
                        "选择角色程序": {
                            "attach": {
                                "update_frequency": "never"
                            }
                        },
                        "选择角色程序_onlyNode": {
                            "attach": {
                                "update_frequency": "never"
                            }
                        },
                        "选择角色程序_矩阵循生": {
                            "attach": {
                                "update_frequency": "never"
                            }
                        }
                    },
                    "label": "$case.角色缓存更新频率.永不过期"
                }
            ]
        },
        "多账号缓存": {
            "label": "$option.多账号缓存.label",
            "description": "$option.多账号缓存.description",
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "角色缓存账号前缀"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "缓存组件信息": {
            "label": "$option.缓存组件信息.label",
            "description": "$option.缓存组件信息.description",
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "覆盖布局菜单": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "覆盖布局菜单": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "角色缓存账号前缀": {
            "label": "$option.角色缓存账号前缀.label",
            "description": "$option.角色缓存账号前缀.description",
            "type": "input",
            "inputs": [
                {
                    "name": "账号前缀",
                    "label": "$input.角色缓存账号前缀.账号前缀.label",
                    "description": "$input.角色缓存账号前缀.账号前缀.description",
                    "default": "main",
                    "pipeline_type": "string",
                    "verify": "^[\\w\\u4e00-\\u9fff\\-]{1,32}$",
                    "pattern_msg": "$input.角色缓存账号前缀.账号前缀.pattern_msg"
                }
            ],
            "pipeline_override": {
                "是否需要缓存": {
                    "recognition": {
                        "param": {
                            "custom_recognition_param": {
                                "cache_prefix": "{账号前缀}"
                            }
                        }
                    }
                },
                "选择角色程序": {
                    "attach": {
                        "cache_prefix": "{账号前缀}"
                    }
                },
                "选择角色程序_onlyNode": {
                    "attach": {
                        "cache_prefix": "{账号前缀}"
                    }
                },
                "选择角色程序_矩阵循生": {
                    "attach": {
                        "cache_prefix": "{账号前缀}"
                    }
                },
                "缓存角色程序": {
                    "attach": {
                        "cache_prefix": "{账号前缀}"
                    }
                }
            }
        },
        "切换服务器": {
            "label": "$option.切换服务器.label",
            "description": "$option.切换服务器.description",
            "type": "select",
            "controller": [
                "Android"
            ],
            "cases": [
                {
                    "name": "官服",
                    "pipeline_override": {},
                    "label": "$case.切换服务器.官服"
                },
                {
                    "name": "云战双",
                    "pipeline_override": {
                        "进入游戏": {
                            "recognition": {
                                "type": "OCR",
                                "param": {
                                    "roi": [
                                        884,
                                        600,
                                        112,
                                        60
                                    ],
                                    "expected": [
                                        "进入游戏"
                                    ]
                                }
                            },
                            "action": {
                                "type": "Click",
                                "param": {
                                    "target": true
                                }
                            }
                        },
                        "打开应用": {
                            "action": {
                                "type": "StartApp",
                                "param": {
                                    "package": "com.kurogame.haru.cloud/com.kuro.cloudgame.module.splash.KuroSplashActivity"
                                }
                            }
                        },
                        "停止": {
                            "action": {
                                "type": "StopApp",
                                "param": {
                                    "package": "com.kurogame.haru.cloud"
                                }
                            }
                        },
                        "重启游戏": {
                            "action": {
                                "type": "StopApp",
                                "param": {
                                    "package": "com.kurogame.haru.cloud"
                                }
                            },
                            "next": [
                                "启动"
                            ]
                        }
                    },
                    "label": "$case.切换服务器.云战双"
                },
                {
                    "name": "B服",
                    "pipeline_override": {
                        "打开应用": {
                            "action": {
                                "type": "StartApp",
                                "param": {
                                    "package": "com.kurogame.haru.bilibili/com.haru.herousdk.SplashActivity"
