        "./tasks/战斗辅助.json",
        "./tasks/宣叙妄响.json",
        "./tasks/厄愿潮声.json",
        "./tasks/矩阵循生.json",
        "./tasks/寒境曙光.json",
        "./tasks/神寂启示录.json"
