{
    "interface_version": 2,
    "name": "MPA",
    "mirrorchyan_rid": "MAA_Punish",
    "github": "https://github.com/overflow65537/MAA_Punish",
    "license": "./LICENSE",
    "contact": "./CONTACT.md",
    "welcome": "./DISCLAIMER.md",
    "description": "基于全新架构的 战双帕弥什 小助手。图像技术 + 模拟控制，解放双手！由 MaaFramework 强力驱动！",
    "MFW_min_req_version": "99.99.99",
    "icon": "./logo.png",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "description": "<p>仅支持安卓模拟器，不支持官方模拟器。</p><p>请在游戏设置中关闭异形屏适配。</p>"
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "permission_required": true,
            "description": "<p>请正确填写程序路径为游戏入口PGR.exe而非启动器的launcher.exe</p><p>填写后可以使用自动启动游戏功能</p><p>桌面端目前不是很稳定,如果出现过多错误,请尝试使用安卓端</p><p>控制方式推荐使用SendMessageWithCursorPos(全屏)或者SendMessageWithWindowPos(窗口)</p>",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "^(战双帕弥什|戰雙帕彌什)$",
                "screencap": "PrintWindow",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "SendMessageWithCursorPos"
            },
            "attach_resource_path": [
                "./resource/pgr_win32"
            ]
        },
        {
            "name": "PlayCover端",
            "type": "PlayCover",
            "description": "<p style=\"color: red; font-weight: bold;\">Macos 专用,支持PlayCover</p><p>playcover无法自己启动游戏</p>",
            "playcover": {
                "uuid": "maa.playcover"
            },
            "attach_resource_path": [
                "./resource/playcover"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "{PROJECT_DIR}/MPAcustom/main.py"
        ],
        "embedded": true
    },
    "global_option": [
        "切换服务器",
        "自动QTE",
        "自动切换角色",
        "同时选择多名角色",
        "跳过分辨率警告",
        "自定义键位"
    ],
    "resource": [
        {
            "name": "简体中文",
            "path": [
                "./resource/base"
            ]
        },
        {
            "name": "繁体中文",
            "path": [
                "./resource/base",
                "./resource/zh_TW"
            ]
        }
    ],
    "task": [],
    "import": [
        "./tasks/进入游戏.json",
        "./tasks/兑换码.json",
        "./tasks/指挥局.json",
        "./tasks/拟真围剿.json",
        "./tasks/诺曼复兴战.json",
        "./tasks/幻痛囚笼.json",
        "./tasks/纷争战区.json",
        "./tasks/历战映射.json",
        "./tasks/刷A级碎片.json",
        "./tasks/领取体力.json",
        "./tasks/领取邮件.json",
        "./tasks/购买物品.json",
        "./tasks/宿舍任务.json",
        "./tasks/拟战场域.json",
        "./tasks/维系者行动.json",
        "./tasks/领取任务.json",
        "./tasks/战令.json",
        "./tasks/结束游戏.json",
        "./tasks/手动更新角色缓存.json",
        "./tasks/洗词缀.json",
