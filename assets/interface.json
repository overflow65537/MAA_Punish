    "option": {
        "角色缓存更新频率": {
            "label": "角色缓存更新频率",
            "description": "角色信息缓存的更新频率，过期后将自动更新角色信息",
            "type": "select",
            "cases": [
                {
                    "name": "每周",
                    "pipeline_override": {
                        "是否需要缓存": {
                            "recognition": {
                                "param": {
                                    "custom_recognition_param": {
                                        "update_frequency": "weekly"
                                    }
                                }
                            }
                        },
                        "选择角色程序": {
                            "attach": {
                                "update_frequency": "weekly"
                            }
                        },
                        "选择角色程序_onlyNode": {
                            "attach": {
                                "update_frequency": "weekly"
                            }
                        },
                        "选择角色程序_矩阵循生": {
                            "attach": {
                                "update_frequency": "weekly"
                            }
                        }
                    }
                },
                {
                    "name": "每月",
                    "pipeline_override": {
                        "是否需要缓存": {
                            "recognition": {
                                "param": {
                                    "custom_recognition_param": {
                                        "update_frequency": "monthly"
                                    }
                                }
                            }
                        },
                        "选择角色程序": {
                            "attach": {
                                "update_frequency": "monthly"
                            }
                        },
                        "选择角色程序_onlyNode": {
                            "attach": {
                                "update_frequency": "monthly"
                            }
                        },
                        "选择角色程序_矩阵循生": {
                            "attach": {
                                "update_frequency": "monthly"
                            }
                        }
                    }
                },
                {
                    "name": "永不过期",
                    "pipeline_override": {
                        "是否需要缓存": {
                            "recognition": {
                                "param": {
                                    "custom_recognition_param": {
                                        "update_frequency": "never"
                                    }
                                }
                            }
                        },
                        "选择角色程序": {
                            "attach": {
                                "update_frequency": "never"
                            }
                        },
                        "选择角色程序_onlyNode": {
                            "attach": {
                                "update_frequency": "never"
                            }
                        },
                        "选择角色程序_矩阵循生": {
                            "attach": {
                                "update_frequency": "never"
                            }
                        }
                    }
                }
            ]
        },
        "多账号缓存": {
            "label": "多账号缓存",
            "description": "为不同账号使用独立的角色缓存文件；开启后需填写前缀，文件名为「前缀_role_cache.json」",
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "角色缓存账号前缀"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "缓存组件信息": {
            "label": "缓存组件信息",
            "description": "如果更改了按钮位置可以打开,程序会自动定位并偏移组件识别区域，无需重新设置",
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "覆盖布局菜单": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "覆盖布局菜单": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "角色缓存账号前缀": {
            "label": "角色缓存账号前缀",
            "description": "用于区分多账号缓存，仅允许字母、数字、中文、下划线与连字符",
            "type": "input",
            "inputs": [
                {
                    "name": "账号前缀",
                    "label": "账号前缀",
                    "description": "例如 main、小号1；对应 assets/前缀_role_cache.json",
                    "default": "main",
                    "pipeline_type": "string",
                    "verify": "^[\\w\\u4e00-\\u9fff\\-]{1,32}$",
                    "pattern_msg": "请输入 1–32 位有效前缀（字母、数字、中文、_、-）"
                }
            ],
            "pipeline_override": {
                "是否需要缓存": {
                    "recognition": {
                        "param": {
                            "custom_recognition_param": {
                                "cache_prefix": "{账号前缀}"
                            }
                        }
                    }
                },
                "选择角色程序": {
                    "attach": {
                        "cache_prefix": "{账号前缀}"
                    }
                },
                "选择角色程序_onlyNode": {
                    "attach": {
                        "cache_prefix": "{账号前缀}"
                    }
                },
                "选择角色程序_矩阵循生": {
                    "attach": {
                        "cache_prefix": "{账号前缀}"
                    }
                },
                "缓存角色程序": {
                    "attach": {
                        "cache_prefix": "{账号前缀}"
                    }
                }
            }
        },
