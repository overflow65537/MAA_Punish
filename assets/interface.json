        "跳过分辨率警告": {
            "label": "是否跳过分辨率警报",
            "description": "打开后将跳过分辨率不符的警告提示",
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "检查分辨率": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "检查分辨率": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "自定义键位": {
            "label": "是否启用自定义键位",
            "description": "打开后可以自定义游戏中的按键设置",
            "type": "switch",
            "default_case": "No",
            "controller": [
                "桌面端"
            ],
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "输入键码"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "输入键码": {
            "type": "input",
            "label": "按键设置",
            "description": "请输入对应按键的键码",
            "inputs": [
                {
                    "name": "攻击",
                    "default": "74",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入有效的数字键码"
                },
                {
                    "name": "闪避",
                    "default": "75",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入有效的数字键码"
                },
                {
                    "name": "技能",
                    "default": "76",
