{
    "interface_version": 2,
    "name": "FOS",
    "label": "$project.label",
    "languages": {
        "zh_cn": "./i18n/zh_cn.json",
        "zh_tw": "./i18n/zh_tw.json"
    },
    "mirrorchyan_rid": "MAA_Punish",
    "github": "https://github.com/overflow65537/MAA_Punish",
    "license": "./LICENSE",
    "contact": "$contact",
    "welcome": "$welcome",
    "description": "$project.description",
    "MFW_min_req_version": "99.99.99",
    "icon": "./logo.png",
    "controller": [
        {
            "name": "Android",
            "type": "Adb",
            "description": "$controller.Android.description",
            "label": "$controller.Android.label"
        },
        {
            "name": "Win32-Window",
            "description": "$controller.Win32-Window.description",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "^(战双帕弥什|戰雙帕彌什)$",
                "screencap": "Background",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "SendMessageWithCursorPos"
            },
            "permission_required": true,
            "attach_resource_path": [
                "./resource/pgr_win32"
            ],
            "label": "$controller.Win32-Window.label"
        },
        {
            "name": "Win32-Window-Background",
            "description": "$controller.Win32-Window-Background.description",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "^(战双帕弥什|戰雙帕彌什)$",
                "screencap": "PrintWindow",
                "mouse": "SendMessageWithWindowPos",
                "keyboard": "SendMessageWithWindowPos"
            },
            "permission_required": true,
            "attach_resource_path": [
                "./resource/pgr_win32"
            ],
            "label": "$controller.Win32-Window-Background.label"
        },
        {
            "name": "Win32-Window-Front",
            "description": "$controller.Win32-Window-Front.description",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "^(战双帕弥什|戰雙帕彌什)$",
                "screencap": "ScreenDC",
                "mouse": "Seize",
                "keyboard": "Seize"
            },
            "permission_required": true,
            "attach_resource_path": [
                "./resource/pgr_win32"
            ],
            "label": "$controller.Win32-Window-Front.label"
        },
        {
            "name": "PlayCover",
            "type": "PlayCover",
            "description": "$controller.PlayCover.description",
            "playcover": {
                "uuid": "maa.playcover"
            },
            "attach_resource_path": [
                "./resource/playcover"
            ],
            "label": "$controller.PlayCover.label"
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "{PROJECT_DIR}/MPAcustom/main.py"
        ],
        "embedded": true
    },
    "global_option": [
        "切换服务器",
        "缓存组件信息",
        "角色缓存更新频率",
        "多账号缓存",
        "自动QTE",
        "自动切换角色",
        "同时选择多名角色",
        "自定义键位"
    ],
    "resource": [
        {
            "name": "zh_CN",
            "description": "$resource.zh_CN.description",
            "path": [
                "./resource/base"
            ],
            "label": "$resource.zh_CN.label"
        },
        {
            "name": "zh_TW",
            "description": "$resource.zh_TW.description",
            "path": [
                "./resource/base",
                "./resource/zh_TW"
            ],
            "label": "$resource.zh_TW.label"
        }
    ],
    "task": [],
    "group": [
        {
            "name": "daily",
            "label": "$group.daily.label",
            "description": "$group.daily.description",
            "default_expand": true
        },
        {
            "name": "roguelike",
            "label": "$group.roguelike.label",
            "description": "$group.roguelike.description",
            "default_expand": true
        },
        {
            "name": "tools",
