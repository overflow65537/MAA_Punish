    "icon": "./logo.png",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "description": "<p>仅支持安卓模拟器，不支持官方模拟器。</p><p>请在游戏设置中关闭异形屏适配。</p>"
        },
        {
            "name": "Win32-Window",
            "label": "Win32控制器-通用",
            "description": "<p>通用Win32控制器，兼容性更好，偶尔会占用鼠标</p><p>需要管理员权限</p><p>请正确填写程序路径为游戏入口PGR.exe而非启动器的launcher.exe</p>",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "^(战双帕弥什|戰雙帕彌什)$",
                "screencap": "Background",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "SendMessageWithCursorPos"
            },
            "permission_required": true,
            "attach_resource_path": [
                "./resource/pgr_win32"
            ]
        },
        {
            "name": "Win32-Window-Background",
            "label": "Win32控制器-后台",
            "description": "<p>Win32控制器-后台，完全不占用鼠标，需要游戏处于窗口模式生效</p><p>需要管理员权限</p><p>请正确填写程序路径为游戏入口PGR.exe而非启动器的launcher.exe</p>",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "^(战双帕弥什|戰雙帕彌什)$",
                "screencap": "PrintWindow",
                "mouse": "SendMessageWithWindowPos",
                "keyboard": "SendMessageWithWindowPos"
            },
            "permission_required": true,
            "attach_resource_path": [
                "./resource/pgr_win32"
            ]
        },
        {
            "name": "Win32-Window-Front",
            "label": "Win32控制器-前台",
            "description": "<p>Win32控制器-前台，占用鼠标，最强的兼容性</p><p>需要管理员权限</p><p>请正确填写程序路径为游戏入口PGR.exe而非启动器的launcher.exe</p>",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "^(战双帕弥什|戰雙帕彌什)$",
                "screencap": "ScreenDC",
                "mouse": "Seize",
                "keyboard": "Seize"
            },
            "permission_required": true,
            "attach_resource_path": [
                "./resource/pgr_win32"
            ]
        },
        {
            "name": "PlayCover端",
            "type": "PlayCover",
            "description": "<p style=\"color: red; font-weight: bold;\">Macos 专用,支持PlayCover</p><p>playcover无法自己启动游戏</p>",
            "playcover": {
                "uuid": "maa.playcover"
            },
            "attach_resource_path": [
                "./resource/playcover"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "{PROJECT_DIR}/MPAcustom/main.py"
        ],
        "embedded": true
    },
