        "选择终极区战斗角色": {
            "label": "请输入角色全名",
            "type": "input",
            "inputs": [
                {
                    "name": "角色名1",
                    "description": "<p>请输入角色全名，例如：露西亚·深红囚影,。</p>",
                    "default": "露西亚·深红囚影",
                    "pipeline_type": "string",
                    "verify": ".*·.*",
                    "pattern_msg": "角色名应包含一个“·”符号(dian)，例如：露西亚·深红囚影"
                },
